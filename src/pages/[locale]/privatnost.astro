---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const pages = await getLocalizedCollection("editorial", typedLocale);
const page = pages.find((p) => p.data.page_key === "privacy");

const fallback: Record<Locale, { title: string; body: string }> = {
  hr: { title: "Izjava o privatnosti", body: "Ova Izjava o privatnosti na jasan i razumljiv način objašnjava koje osobne podatke prikupljamo prilikom slanja upita putem web-stranice apartmani-novoselec.ch, svrhu njihova prikupljanja, način obrade te vaša prava.\n\nVoditelj obrade podataka za web-stranicu apartmani-novoselec.ch je vlasnik objekta Apartmani Novoselec, Ždrelac, Pašman, Hrvatska.\n\nPutem obrasca za upite prikupljamo sljedeće osobne podatke: ime i prezime, adresu e-pošte, broj telefona i sadržaj vaše poruke.\n\nVaše osobne podatke prikupljamo isključivo u svrhu odgovora na vaš upit, pružanja informacija o raspoloživosti smještaja i dogovora o potencijalnoj rezervaciji.\n\nPravna osnova za obradu vaših podataka je članak 6. stavak 1. točka (b) Opće uredbe o zaštiti podataka (GDPR), s obzirom na to da je obrada nužna za poduzimanje radnji na vaš zahtjev prije sklapanja ugovora.\n\nVaši podaci pohranjuju se u bazi podataka Cloudflare D1 koja se nalazi na poslužiteljima unutar Europske unije, čime se osigurava visoka razina sigurnosti.\n\nVaše osobne podatke ne prodajemo, ne iznajmljujemo niti prosljeđujemo trećim stranama. Podaci se mogu dijeliti isključivo s pružateljima tehničkih usluga koji održavaju našu web-stranicu, i to u strogo kontroliranim uvjetima.\n\nPrikupljeni podaci čuvaju se onoliko dugo koliko je potrebno za obradu vašeg upita i pripremu rezervacije. Ukoliko do rezervacije ne dođe, vaši podaci bit će sigurno obrisani.\n\nU svakom trenutku imate pravo zatražiti pristup svojim osobnim podacima, njihov ispravak ili potpuno brisanje kontaktiranjem voditelja obrade putem e-pošte hello@novoselec.ch." },
  de: { title: "Datenschutzerklärung", body: "Diese Datenschutzerklärung erläutert auf klare und verständliche Weise, welche personenbezogenen Daten wir erheben, wenn ihr uns über die Website apartmani-novoselec.ch kontaktiert, warum wir diese erheben, wie wir sie verwenden und welche Rechte ihr habt.\n\nVerantwortlicher für die Datenverarbeitung auf der Website apartmani-novoselec.ch ist der Eigentümer der Apartmani Novoselec, Ždrelac, Pašman, Kroatien.\n\nÜber das Anfrageformular erheben wir folgende personenbezogene Daten: Vor- und Nachname, E-Mail-Adresse, Telefonnummer und den Inhalt eurer Nachricht.\n\nWir erheben und verwenden eure Daten ausschliesslich zu dem Zweck, auf eure Anfrage zu antworten, euch Informationen zur Verfügbarkeit mitzuteilen und eine mögliche Buchung vorzubereiten.\n\nDie Rechtsgrundlage für die Verarbeitung eurer Daten ist Art. 6 Abs. 1 lit. b DSGVO, da die Verarbeitung für die Erfüllung von vorvertraglichen Massnahmen erforderlich ist, die auf eure Anfrage hin erfolgen.\n\nEure Daten werden in einer Cloudflare D1 Datenbank gespeichert, die auf Servern innerhalb der Europäischen Union gehostet wird, um ein hohes Mass an Datensicherheit zu gewährleisten.\n\nWir verkaufen, vermieten oder geben eure personenbezogenen Daten nicht an Dritte weiter. Eine Weitergabe erfolgt ausschliesslich an technische Dienstleister, die den Betrieb unserer Website sicherstellen und vertraglich zur Vertraulichkeit verpflichtet sind.\n\nWir speichern eure Daten nur so lange, wie es für die Bearbeitung eurer Anfrage und die Vorbereitung der Buchung erforderlich ist. Kommt keine Buchung zustande, werden eure Daten sicher gelöscht.\n\nIhr habt jederzeit das Recht, Auskunft über eure gespeicherten personenbezogenen Daten zu erhalten, sowie das Recht auf Berichtigung oder Löschung dieser Daten. Kontaktiert uns unter hello@novoselec.ch." },
  sl: { title: "Izjava o zasebnosti", body: "Ta izjava o zasebnosti na jasen in razumljiv način pojasnjuje, katere osebne podatke zbiramo, ko pošljete povpraševanje prek spletne strani apartmani-novoselec.ch, zakaj jih zbiramo, kako jih obdelujemo in kakšne so vaše pravice.\n\nUpravljavec podatkov za spletno stran apartmani-novoselec.ch je lastnik nastanitve Apartmani Novoselec, Ždrelac, Pašman, Hrvaška.\n\nPrek obrazca za povpraševanje zbiramo naslednje osebne podatke: ime in priimek, e-poštni naslov, telefonsko številko in vsebino vašega sporočila.\n\nVaše osebne podatke zbiramo izključno z namenom odgovora na vaše povpraševanje, posredovanja informacij o razpoložljivosti in dogovora o morebitni rezervaciji.\n\nPravna podlaga za obdelavo vaših podatkov je točka (b) 1. odstavka 6. člena Splošne uredbe o varstvu podatkov (GDPR), saj je obdelava potrebna za izvajanje ukrepov na vašo zahtevo pred sklenitvijo pogodbe.\n\nVaši podatki so shranjeni v podatkovni bazi Cloudflare D1, ki gostuje na strežnikih znotraj Evropske unije, kar zagotavlja visoko raven varnosti.\n\nVaših osebnih podatkov ne prodajamo, ne dajemo v najem in ne posredujemo tretjim osebam. Podatke lahko delimo izključno s ponudniki tehničnih storitev, ki vzdržujejo našo spletno stran pod strogo nadzorovanimi pogoji.\n\nZbrane podatke hranimo le toliko časa, kolikor je potrebno za obdelavo vašega povpraševanja in pripravo rezervacije. Če do rezervacije ne pride, bodo vaši podatki varno izbrisani.\n\nKadar koli imate pravico zahtevati dostop do svojih osebnih podatkov, njihov popravek ali popoln izbris, tako da se obrnete na upravljavca prek e-pošte hello@novoselec.ch." },
  en: { title: "Privacy Policy", body: "This Privacy Policy explains in a clear and understandable manner what personal data we collect when you submit an inquiry via the website apartmani-novoselec.ch, why we collect it, how we process it, and what your rights are.\n\nThe data controller for the website apartmani-novoselec.ch is the owner of Apartmani Novoselec, Ždrelac, Pašman, Croatia.\n\nThrough the inquiry form, we collect the following personal data: your first and last name, email address, phone number, and the content of your message.\n\nWe collect your personal data solely to respond to your inquiry, provide information about accommodation availability, and arrange a potential booking.\n\nThe legal basis for processing your data is Article 6(1)(b) of the General Data Protection Regulation (GDPR), as processing is necessary to take steps at your request prior to entering into a contract.\n\nYour data is stored in a Cloudflare D1 database hosted on servers located within the European Union, ensuring a high level of data security.\n\nWe do not sell, rent, or share your personal data with third parties. Data may only be shared with technical service providers who maintain our website, under strictly controlled conditions.\n\nCollected data is retained only as long as necessary to process your inquiry and prepare your booking. If no booking is made, your data will be securely deleted.\n\nYou have the right to request access to your personal data, as well as the right to have it rectified or completely erased at any time by contacting the data controller at hello@novoselec.ch." },
};

const title = (page?.data.title as string) ?? fallback[typedLocale].title;
const body = (page?.data.body as string) ?? fallback[typedLocale].body;
---

<Page title={title} locale={typedLocale}>
  <HeroSimple title={title} image="/api/img/c4b47191-7259-4d17-96f6-53e50f918346" />

  <section class="section">
    <div class="container legal-content">
      {body.split("\n\n").map((paragraph) => (
        <p style="white-space: pre-line">{paragraph}</p>
      ))}
    </div>
  </section>
</Page>

<style>
  .legal-content {
    max-width: 700px;
    margin-inline: auto;
  }

  .legal-content p {
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }
</style>
