---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import MiniCollage from "~/components/ui/MiniCollage.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { getLocalizedCollection, parsePhotoArray } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const title: Record<Locale, string> = {
  hr: "Hrana i piće", de: "Essen & Trinken", sl: "Hrana in pijača", en: "Food & Drink",
};

const intro: Record<Locale, string> = {
  hr: "Na Pašmanu i Ugljanu kuhinja je jednostavna i samouvjerena. Riba dolazi iz mora ispred vas, maslinovo ulje sa susjednog brda, a peka čeka svoj ritam pod poklopcem. Ovdje se kuha polako, jede s ljudima do sebe, i sve nekako bolje prolazi kad se čuje more.",
  de: "Auf Pašman und Ugljan ist die Küche einfach und selbstbewusst. Der Fisch kommt aus dem Meer direkt vor euch, das Olivenöl vom Hügel nebenan, und die Peka wartet geduldig unter dem Deckel auf ihren Moment. Hier kocht man langsam, isst mit den Menschen am Tisch - und alles schmeckt ein bisschen besser, wenn man das Meer hört.",
  sl: "Na Pašmanu in Ugljanu je kuhinja preprosta in samozavestna. Riba pride iz morja pred vami, oljčno olje s sosednjega hriba, peka pa pod pokrovom počaka na svoj ritem. Tukaj se kuha počasi, je v dobri družbi - in vse nekako lepše steče, ko se sliši morje.",
  en: "On Pašman and Ugljan, the cooking is simple and sure of itself. Fish comes from the sea in front of you, olive oil from the hill next door, and peka keeps its own rhythm under the lid. Here, we cook slowly, eat with the people beside us, and somehow everything goes down easier when you can hear the sea.",
};

const cmsEntries = await getLocalizedCollection("hrana", typedLocale);
const entry = cmsEntries[0];
const sectionTitle = (entry?.data.title as string) ?? title[typedLocale];
const body = (entry?.data.body as string) ?? "";
const allPhotos = parsePhotoArray(entry?.data.gallery);

// Split photos into two halves for two collages
const mid = Math.ceil(allPhotos.length / 2);
const photosLeft = allPhotos.slice(0, mid);
const photosRight = allPhotos.slice(mid);
---

<Page title={title[typedLocale]} locale={typedLocale} ogImage="https://novoselec.hr/api/img/073aa7b8-b7d8-4da9-932d-d39caa24df2a">
  <HeroSimple title={title[typedLocale]} intro={intro[typedLocale]} image="/api/img/073aa7b8-b7d8-4da9-932d-d39caa24df2a" />

  {/* Description */}
  <section class="section" data-reveal>
    <div class="container">
      <h2 class="editorial-title">{sectionTitle}</h2>
    </div>
    <div class="container">
      <p class="editorial-text">{body}</p>
    </div>
  </section>

  {/* Both collages at bottom - one above the other */}
  <div style="padding-bottom: var(--space-section);">
    {photosLeft.length > 1 && (
      <div class="editorial-strip">
        <MiniCollage images={photosLeft} speed={Math.max(35, photosLeft.length * 8)} />
      </div>
    )}

    {photosRight.length > 1 && (
      <div class="editorial-strip" style="margin-top: var(--space-md);">
        <MiniCollage images={photosRight} speed={Math.max(35, photosRight.length * 8)} reverse />
      </div>
    )}
  </div>
</Page>
