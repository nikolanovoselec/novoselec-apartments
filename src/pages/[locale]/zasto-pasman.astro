---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import MiniCollage from "~/components/ui/MiniCollage.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection, parsePhotoArray } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const cmsEntries = (await getLocalizedCollection("editorial", typedLocale))
  .filter((e) => e.data.page_key === "why-pasman")
  .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0));

const sections = cmsEntries.map((e) => ({
  title: (e.data.title as string) ?? "",
  text: (e.data.body as string) ?? "",
  image: (e.data.image as string) ?? "",
  gallery: parsePhotoArray(e.data.gallery),
}));
---

<Page title={t(typedLocale, "nav.whyPasman")} locale={typedLocale} ogImage="https://apartmani.novoselec.ch/api/img/216f0b04-b41f-491d-8921-bb5621c347fc">
  <HeroSimple title={t(typedLocale, "nav.whyPasman")} image="/api/img/216f0b04-b41f-491d-8921-bb5621c347fc" />

  {sections.map((section, i) => {
    const photos = section.gallery.length > 0
      ? section.gallery
      : section.image ? [{ src: section.image, alt: section.title }] : [];
    return (
      <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
        <div class="container">
          <h2 class="editorial-title">{section.title}</h2>
        </div>
        {photos.length > 0 && (
          <div class="editorial-strip">
            <MiniCollage images={photos} speed={18 + i * 4} />
          </div>
        )}
        <div class="container">
          <p class="editorial-text">{section.text}</p>
        </div>
      </section>
    );
  })}

  <section class="section" data-reveal>
    <div class="container text-center">
      <a href={`/${typedLocale}/apartmani`} class="btn btn--primary">
        {t(typedLocale, "nav.apartments")}
      </a>
    </div>
  </section>
</Page>
